{
    "name": "imransaleem/security-suite",
    "description": "Laravel security package: audit logs, password policy, idle timeout, login block, HTTP request logging.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "security",
        "audit-log",
        "password-policy",
        "idle-timeout",
        "login-block"
    ],
    "authors": [
        {
            "name": "Imran Saleem",
            "homepage": "https://github.com/imransaleem"
        }
    ],
    "homepage": "https://github.com/imransaleem/security-suite",
    "support": {
        "issues": "https://github.com/imransaleem/security-suite/issues",
        "source": "https://github.com/imransaleem/security-suite"
    },
    "autoload": {
        "psr-4": {
            "ImranSaleem\\SecuritySuite\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ImranSaleem\\SecuritySuite\\SecuritySuiteServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^7.4|^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0",
        "illuminate/database": "^8.0|^9.0|^10.0",
        "illuminate/http": "^8.0|^9.0|^10.0",
        "illuminate/routing": "^8.0|^9.0|^10.0",
        "illuminate/validation": "^8.0|^9.0|^10.0"
    },
    "suggest": {
        "spatie/laravel-permission": "Required for admin UI routes that use the role middleware (^5.0)"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
